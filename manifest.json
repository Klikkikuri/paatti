{
  "manifest_version": 2,
  "name": "Klikkikuri Paatti",
  "version": "0.0.1",
  // This is needed to use settings across the different scripts.
  "browser_specific_settings": {
    "gecko": {
      "id": "klikkikuri@example.com"
    }
  },
  "icons": {
      "48": "icons/klikkikuri-48.png"
  },
  "browser_action": {
    "default_icon": {
      "19": "icons/klikkikuri-19.png",
      "38": "icons/klikkikuri-38.png"
    },
    "default_title": "Paatti",
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.iltalehti.fi/*", "https://*.hs.fi/*", "https://yle.fi/*"],
      "js": ["constants.js", "content_scripts/changeHeadlines.js"]
    }
  ],
  "background": {
    "scripts": ["constants.js", "background.js"],
    "persistent": false
  },
  "permissions": [
      // TODO: Add API address here.
      "http://localhost/*",
      "storage",
      "activeTab"
  ]
}
