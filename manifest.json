{
  "manifest_version": 3,
  "name": "Klikkikuri Paatti",
  "description": "Tunnistaa ja oikaisee sensaatiohakuiset uutisotsikot kun selailet verkkolehtien uutissivuja.",
  "version": "0.0.6",
  "browser_specific_settings": {
    "gecko": {
      "id": "klikkikuri@protonmail.com",
      "strict_min_version": "128.0",
      "update_url": "https://raw.githubusercontent.com/Klikkikuri/paatti/main/updates.json",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "minimum_chrome_version": "122.0",
  "homepage_url": "https://github.com/klikkikuri",
  "icons": {
    "48": "icons/klikkikuri-48.png"
  },
  "default_locale": "fi",
  "action": {
    "default_icon": {
      "19": "icons/klikkikuri-19.png",
      "38": "icons/klikkikuri-38.png"
    },
    "default_title": "Klikkikuri Paatti",
    "default_popup": "src/options/popup.html",
    "default_area": "navbar"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/klikkikuri-48.png",
        "src/utils.js",
        "src/model.js",
        "src/controller.js",
        "src/config.js",
        "src/storage.js",
        "src/rahti.js",
        "src/modifiers.js",
        "build/js.wasm"
      ],
      "matches": [
        "https://www.iltalehti.fi/*",
        "https://www.hs.fi/*",
        "https://yle.fi/*",
        "https://www.mtvuutiset.fi/*",
        "https://aksa.fi/*",
        "https://www.ampparit.com/*",
        "https://old.reddit.com/*"
      ]
    }
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ],
    "service_worker": "src/background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://raw.githubusercontent.com/Klikkikuri/rahti/*",
    "https://www.iltalehti.fi/*",
    "https://www.hs.fi/*",
    "https://yle.fi/*",
    "https://www.mtvuutiset.fi/*",
    "https://aksa.fi/*"
  ],
  "optional_host_permissions": [
    "https://www.ampparit.com/*",
    "http://localhost/*"
  ],
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none';"
  }
}
