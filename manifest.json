{
  "manifest_version": 2,
  "name": "Klikkikuri Paatti",
  "version": "0.0.1",
  "icons": {
      "48": "assets/klikkikuri-48.png"
  },
  "browser_action": {
    "default_icon": {
      "19": "assets/klikkikuri-19.png",
      "38": "assets/klikkikuri-38.png"
    },
    "default_title": "Paatti",
    "default_popup": "./popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.iltalehti.fi/*", "https://*.hs.fi/*", "https://yle.fi/*"],
      "js": ["./src/index.js"]
    }
  ],
  // TODO: Add API address matcher here.
  "permissions": [
      "http://localhost/*"
  ]
}
