{
  "manifest_version": 3,
  "name": "Klikkikuri Paatti",
  "version": "0.0.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "klikkikuri@protonmail.com"
    }
  },
  "icons": {
    "48": "icons/klikkikuri-48.png"
  },
  "action": {
    "default_icon": {
      "19": "icons/klikkikuri-19.png",
      "38": "icons/klikkikuri-38.png"
    },
    "default_title": "Paatti",
    "default_popup": "src/popup/html/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/utils.js",
        "src/conversionUtils.js",
        "src/model.js",
        "src/controller.js",
        "suola/build/suola.js",
        "suola/build/js.wasm",
        "test_data/data.json"
      ],
      "matches": [
        "https://*.iltalehti.fi/*",
        "https://*.hs.fi/*",
        "https://yle.fi/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.iltalehti.fi/*",
        "https://*.hs.fi/*",
        "https://yle.fi/*"
      ],
      "js": [
        // Glue code provided with Go.
        "suola/build/wasm_exec.js",
        // This script should contain an initialization function for the WebAssembly module.
        "suola/build/suola.js",
        // Associated test data.
        "test_data/urls.js",
        // Main module.
        "src/changeHeadlines.js"
      ]
    }
  ],
  "background": {
    "scripts": ["src/background.js"],
    "service_worker": "src/background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "http://localhost/*"
  ],
  "permissions": [
    "storage",
    "tabs"
  ]
}
