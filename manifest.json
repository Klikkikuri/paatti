{
  "manifest_version": 3,
  "name": "Klikkikuri Paatti",
  "description": "Tunnistaa ja oikaisee sensaatiohakuiset uutisotsikot kun selailet verkkolehtien uutissivuja.",
  "version": "0.0.3",
  "browser_specific_settings": {
    "gecko": {
      "id": "klikkikuri@protonmail.com",
      "update_url": "https://raw.githubusercontent.com/Klikkikuri/paatti/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "homepage_url": "https://github.com/klikkikuri",
  "icons": {
    "48": "icons/klikkikuri-48.png"
  },
  "default_locale": "fi",
  "action": {
    "default_icon": {
      "19": "icons/klikkikuri-19.png",
      "38": "icons/klikkikuri-38.png"
    },
    "default_title": "Paatti",
    "default_popup": "src/options/popup.html",
    "default_area": "navbar"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/klikkikuri-48.png",
        "src/utils.js",
        "src/model.js",
        "src/controller.js",
        "src/config.js",
        "src/storage.js",
        "src/rahti.js",
        "suola/build/suola.js",
        "suola/build/js.wasm",
        "test_data/data.json"
      ],
      "matches": [
        "https://*.iltalehti.fi/*",
        "https://*.hs.fi/*",
        "https://yle.fi/*",
        "https://www.mtvuutiset.fi/*",
        "https://aksa.fi/*"
      ]
    }
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ],
    "service_worker": "src/background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://*.iltalehti.fi/*",
    "https://*.hs.fi/*",
    "https://yle.fi/*",
    "https://www.mtvuutiset.fi/*",
    "https://aksa.fi/*"
  ],
  "optional_host_permissions": [
    "http://localhost/*"
  ],
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting"
  ]
}
