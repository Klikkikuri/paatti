{
  "manifest_version": 3,
  "name": "Klikkikuri Paatti",
  "description": "__MSG_extensionDescription__",
  "version": "0.0.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "klikkikuri@protonmail.com"
    }
  },
  "icons": {
    "48": "icons/klikkikuri-48.png"
  },
  "default_locale": "fi",
  "action": {
    "default_icon": {
      "19": "icons/klikkikuri-19.png",
      "38": "icons/klikkikuri-38.png"
    },
    "default_title": "Paatti",
    "default_popup": "src/popup/index.html",
    "default_area": "navbar"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/klikkikuri-48.png",
        "src/utils.js",
        "src/conversionUtils.js",
        "src/model.js",
        "src/controller.js",
        "src/config.js",
        "src/storage.js",
        "src/rahti.js"
      ],
      "matches": [
        "https://*.iltalehti.fi/*",
        "https://*.hs.fi/*",
        "https://yle.fi/*",
        "https://www.mtvuutiset.fi/*",
        "https://aksa.fi/*"
      ]
    }
  ],
  
  "content_scripts": [
    {
      "matches": [
        "https://*.iltalehti.fi/*",
        "https://*.hs.fi/*",
        "https://yle.fi/*",
        "https://www.mtvuutiset.fi/*",
        "https://aksa.fi/*"
      ],
      "css": [
        "src/contentStyle.css"
      ],
      "js": [
        "src/contentScript.js"
      ]
    }
  ],
  "background": {
    "scripts": [
      // Glue code provided with Go.
      "suola/build/wasm_exec.js",
      // This script should contain an initialization function for the WebAssembly module.
      "suola/build/suola.js",
      // Main module.
      "src/background.js"
    ],
    "service_worker": "src/background.js",
    "type": "module"
  },
  // This is needed to load Suola in background script.
  "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'"
  },
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "http://localhost/*"
  ],
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ]
}
