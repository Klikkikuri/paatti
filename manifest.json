{
  "manifest_version": 2,
  "name": "Klikkikuri Paatti",
  "version": "0.0.1",
  // This is needed to use settings across the different scripts.
  "browser_specific_settings": {
    "gecko": {
      "id": "klikkikuri@example.com"
    }
  },
  "icons": {
    "48": "icons/klikkikuri-48.png"
  },
  "browser_action": {
    "default_icon": {
      "19": "icons/klikkikuri-19.png",
      "38": "icons/klikkikuri-38.png"
    },
    "default_title": "Paatti",
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.iltalehti.fi/*",
        "https://*.hs.fi/*",
        "https://yle.fi/*"
      ],
      "js": [
        "utils/tools.js",
        // Glue code provided with Go.
        "suola/build/wasm_exec.js",
        // This script should contain an initialization function for the WebAssembly module.
        "suola/build/suola.js",
        // Associated test data.
        "test_data/urls.js",
        // Main module.
        "content_scripts/changeHeadlines.js"
      ]
    }
  ],
  "background": {
    "scripts": [
      "utils/tools.js",
      "background.js"
    ],
    "persistent": false
  },
  "permissions": [
    "https://raw.githubusercontent.com/*",
    "http://localhost/*",
    "storage",
    "activeTab"
  ]
}